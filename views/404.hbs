<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Trang không tìm thấy</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/index.css">
    <script src="https://unpkg.com/phosphor-icons"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anton&display=swap" rel="stylesheet">
</head>
<body>
    <div class="top_bar" style="border-bottom: 1px rgba(140, 140, 140, 0.5) solid;">
        <div class="align_row" style="color: white;">
            <i style="font-size: 40px;" class="ph ph-video-camera"></i>
            <h1 style="font-size: 20px; margin: 0px 20px; font-weight: 600;">UIT THEATER</h1>
        </div>
    </div>

    <div style="text-align:center; padding: 80px 20px; color: #FFF;">
        <h1 style="font-size: 120px; margin: 0;">401</h1>
        <h2 style="font-size: 28px; margin: 10px 0 20px;">Unauthorized. Vui lòng tải gói tài nguyên để xác thực.</h2>
        <a href="/resources/GoiTaiNguyen.exe" download style="display:inline-block; margin-top:20px; padding:12px 24px; background:#663399; color:#fff; border-radius:8px; text-decoration:none;">Tải gói tài nguyên (*.exe)</a>
        <a id="homeBtn" href="#" aria-disabled="true" style="display:inline-block; margin-top:20px; margin-left:12px; padding:12px 24px; background:gray; color:#fff; border-radius:8px; text-decoration:none; pointer-events:none;">Về trang chủ</a>
    </div>

    <div class="bottom_bar" style="margin-top:40px;">
        <div class="align_row">
            <i style="font-size: 50px;" class="ph ph-video-camera"></i>
            <h1 style="font-size: 30px; margin-left: 20px; margin-top: 8px; font-weight: bold;">UIT THEATER</h1>
        </div>
    </div>
</body>
<script>
// Poll /api/verify until server indicates client cert is present, then enable home button
(function(){
    const homeBtn = document.getElementById('homeBtn');
    let attempts = 0;
    const maxAttempts = 40; // ~2 minutes if interval 3s
    const interval = 3000;

    function enableHome() {
        homeBtn.setAttribute('href', '/index');
        homeBtn.style.background = '#4CAF50';
        homeBtn.style.pointerEvents = 'auto';
        homeBtn.removeAttribute('aria-disabled');
        homeBtn.textContent = 'Về trang chủ';
    }

    function check() {
        attempts++;
        fetch('/api/verify')
            .then(r => r.json())
            .then(data => {
                if (data && data.verified) {
                    enableHome();
                } else if (attempts < maxAttempts) {
                    setTimeout(check, interval);
                } else {
                    // give up after max attempts; keep disabled
                }
            })
            .catch(() => {
                if (attempts < maxAttempts) setTimeout(check, interval);
            });
    }

    // Start polling shortly after load
    window.addEventListener('load', () => setTimeout(check, 1000));
})();
</script>
</html>
